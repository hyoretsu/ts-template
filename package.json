{
	"name": "template",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.0",
	"workspaces": [
		"backend",
		"frontend",
		"packages/*"
	],
	"scripts": {
		"build": "turbo build",
		"commit": "git add . && bun committier ai",
		"dev": "turbo dev",
		"format": "bun format:biome . && bun format:eslint .",
		"format:biome": "bunx biome check --diagnostic-level=error --write --unsafe",
		"format:eslint": "bunx eslint --quiet --fix",
		"prepare": "bun run ./prepare.ts || true",
		"start": "turbo start"
	},
	"lint-staged": {
		"**/*.(css|graphql|js|jsx|json|jsonc|ts|tsx)": [
			"bun format:biome --no-errors-on-unmatched"
		],
		"**/*.(js|jsx|ts|tsx)": [
			"bun format:eslint"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@commitlint/types": "^20.5.0",
		"@eslint/js": "^10.0.1",
		"@hyoretsu/configs": "^1.2.33",
		"@types/bun": "^1.3.13",
		"@types/node": "^25.6.0",
		"committier": "^0.2.3",
		"eslint": "^10.3.0",
		"eslint-config-biome": "^2.1.3",
		"lint-staged": "^16.4.0",
		"turbo": "^2.9.7",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1"
	}
}
