{
	"$schema": "https://schema.tauri.app/config/2",
	"app": {
		"security": {
			"csp": null
		},
		"windows": [
			{
				"fullscreen": false,
				"height": 800,
				"resizable": true,
				"title": "Example",
				"width": 400
			}
		],
		"withGlobalTauri": true
	},
	"build": {
		"beforeBuildCommand": "bun build",
		"beforeDevCommand": "bun dev",
		"devUrl": "http://localhost:5173",
		"frontendDist": "../dist"
	},
	"bundle": {
		"active": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"targets": "all"
	},
	"identifier": "com.example.app",
	"productName": "Example",
	"version": "0.1.0"
}
